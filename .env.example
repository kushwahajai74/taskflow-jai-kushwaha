# Copy this file to .env and fill in the real values.
#
#cp .env.example .env
#
PORT=3000
# PostgreSQL connection string (e.g. from Neon, Supabase, or a local Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key used to sign JWT tokens generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

NODE_ENV=production
